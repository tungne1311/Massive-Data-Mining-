# ─────────────────────────────────────────────────────────────────
# .env — biến môi trường cho docker compose
# Đổi theo máy thực tế — KHÔNG commit file này lên git
# ─────────────────────────────────────────────────────────────────

# ── MinIO credentials ─────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── Spark driver (pipeline container) ────────────────────────────
SPARK_DRIVER_MEMORY=4g
SPARK_EXECUTOR_MEMORY=6g
SPARK_EXECUTOR_CORES=4

# ── Spark worker resources (mỗi worker) ──────────────────────────
# Tổng memory máy host nên >= SPARK_WORKER_MEMORY * 2 + 4g (driver + OS)
SPARK_WORKER_MEMORY=8g
SPARK_WORKER_CORES=4

# ── HuggingFace ingestion─────────────────────────────
HF_STREAM_BATCH_SIZE=100000
